---
import Layout from "../layouts/layout.astro";

const {
  role,
  title = "Logs",
  description = "Personal and operational records"
} = Astro.props;

const logModules = import.meta.glob("../pages/logs/**/*.md", { eager: true });

const divisionColors = {
  Command: "command",
  Medical: "sciences",
  Science: "sciences",
  Sciences: "sciences",
  Engineering: "operations",
  Operations: "operations",
  Security: "security",
};

const formatLogType = (frontmatter) => {
  const label =
    frontmatter.logType ??
    frontmatter.pubTitle ??
    frontmatter.title ??
    "Log";

  return String(label).replace(/\s+\d{5}[-.]\d{3}$/, "");
};

const logEntries = Object.entries(logModules)
  .filter(([path]) => {
    if (!role) return true;
    return path.includes(`/logs/${role}/`);
  })
  .map(([path, module]) => {
    const frontmatter = module.frontmatter ?? {};
    const division = frontmatter.division ?? frontmatter.department ?? "Command";

    return {
      division,
      logType: formatLogType(frontmatter),
      stardate: String(frontmatter.stardate ?? "00000.000"),
      author: frontmatter.author ?? "Unknown Author",
      excerpt:
        frontmatter.excerpt ??
        frontmatter.description ??
        "Open record for full log entry.",
      href: path.replace("../pages/logs", "/logs").replace(/\.md$/, ""),
      color: divisionColors[division] ?? "command",
    };
  })
  .sort((a, b) => Number(b.stardate) - Number(a.stardate));

const railItems = [
  ["Total Logs", String(logEntries.length)],
  ["Latest Stardate", logEntries[0]?.stardate ?? "—"],
];
---

<Layout title={title} current="logs">
  <main class="interior-shell">
    <section class="page-hero">
      <p class="eyebrow">Log Archive</p>
      <h1>{title}</h1>
      <p class="dek">{description}</p>
    </section>

    <div class="content-layout">
      <article class="main-content">
        <section class="logs-feed">
          {logEntries.map((log) => (
            <a class={`log-card ${log.color}`} href={log.href}>
              <div class="log-card-inner">
                <p class="log-type">{log.logType}</p>
                <p class="log-excerpt">{log.excerpt}</p>
                <p class="log-stardate">Stardate {log.stardate}</p>
                <div class="log-footer">
                  <span>{log.author}</span>
                  <span>Read Log →</span>
                </div>
              </div>
            </a>
          ))}
        </section>
      </article>

      <aside class="context-rail">
        <section class="rail-card metadata-card">
          <h2>Log Summary</h2>
          <dl>
            {railItems.map(([term, detail]) => (
              <div>
                <dt>{term}</dt>
                <dd>{detail}</dd>
              </div>
            ))}
          </dl>
        </section>
      </aside>
    </div>
  </main>
</Layout>
<style>
.logs-feed {
  display: grid;
  gap: 1.25rem;
}

.log-card {
  display: block;
  color: inherit;
  text-decoration: none;
  background: rgba(255, 255, 255, 0.28);
  border: 1px solid var(--line);
  border-left: 6px solid var(--operations);
  overflow: hidden;
  transition: transform 160ms ease, background 160ms ease;
}

.log-card:hover,
.log-card:focus-visible {
  transform: translateY(-2px);
  background: rgba(255, 255, 255, 0.5);
}

.log-card.command {
  border-left-color: var(--command);
}

.log-card.operations {
  border-left-color: var(--operations);
}

.log-card.sciences {
  border-left-color: var(--sciences);
}

.log-card.security {
  border-left-color: var(--sciences);
}

.log-card-inner {
  padding: 1.35rem 1.5rem 1.25rem;
}

.log-type {
  margin: 0 0 1rem;
  color: var(--operations);
  font-family: "Orbitron", sans-serif;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  line-height: 1.25;
  text-transform: uppercase;
}

.log-card.command .log-type,
.log-card.command .log-footer span:last-child {
  color: var(--command);
}

.log-card.operations .log-type,
.log-card.operations .log-footer span:last-child {
  color: var(--operations);
}

.log-card.sciences .log-type,
.log-card.sciences .log-footer span:last-child,
.log-card.security .log-type,
.log-card.security .log-footer span:last-child {
  color: var(--sciences);
}

.log-excerpt {
  margin: 0;
  overflow: hidden;
  color: var(--ink);
  font-family: "Crimson Text", serif;
  font-size: clamp(1.28rem, 1.75vw, 1.66rem);
  font-weight: 600;
  line-height: 1.12;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.log-stardate {
  margin: 0.85rem 0 1.05rem;
  font-size: 0.95rem;
  opacity: 0.68;
}

.log-footer {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 1rem;
  padding-top: 0.9rem;
  border-top: 1px solid var(--line);
  font-family: "Orbitron", sans-serif;
  font-size: 0.64rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.log-footer span:first-child {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.log-footer span:last-child {
  white-space: nowrap;
}
</style>