---
import Layout from "../layouts/layout.astro";

const archiveCards = [
  {
    label: "FOUNDING\nDOCUMENTS",
    title: "Core Doctrine",
    body: "The foundational records that establish the Frontier Initiative, USS Kepler Doctrine, and Settlement Continuum.",
    href: "/archive/doctrine",
  },
  {
    label: "MISSION\nRECORDS",
    title: "Operational Archive",
    body: "Mission reports, field observations, surveys, and historical records generated by Kepler deployments.",
    href: "/archive/missions",
  },
  {
    label: "CREW &\nVESSEL",
    title: "Reference Files",
    body: "Personnel records, ship specifications, departmental structures, and supporting documentation.",
    href: "/archive/reference",
  },
];

const railItems = [
  ["Section", "Archive"],
  ["Classification", "Memory Alpha Archive"],
  ["Primary Vessel", "USS Kepler NCC-83639"],
  ["Status", "Active"],
  ["Access", "Public"],
];
---

<Layout title="Archive" current="archive">
  <main class="interior-shell">
    <section class="page-hero">
      <p class="eyebrow">Section Overview</p>
      <h1>Archive</h1>
      <p class="dek">
        The central repository for doctrine, mission records, personnel files, and historical documents.
      </p>
    </section>

    <div class="content-layout">
      <article class="main-content">
        <section class="prose-block">
          <h2>Overview</h2>
          <p>
            The Archive serves as the organizing layer for USS Kepler. Every mission,
            report, log entry, doctrine paper, and personnel record ultimately lives here.
            Top-level sections provide orientation. The archive preserves the record.
          </p>
        </section>

        <section class="archive-grid">
          {archiveCards.map((card) => (
            <a class="archive-card" href={card.href}>
              <p class="card-label">{card.label}</p>
              <h2>{card.title}</h2>
              <p>{card.body}</p>
              <span class="card-action">Open Record</span>
            </a>
          ))}
        </section>

        <section class="prose-block section-note">
          <h2>Archive Principle</h2>
          <p>
            The purpose of an archive is not simply preservation. It is continuity.
            Records allow institutions, crews, and communities to learn from what came before.
          </p>
        </section>
      </article>

      <aside class="context-rail">
        <section class="rail-card">
          <p class="rail-kicker">Archive Record</p>
          <h2>Memory Alpha</h2>
          <p>
            The Archive section provides structured access to the complete body of USS Kepler documentation.
          </p>
        </section>

        <section class="rail-card metadata-card">
          <h2>Archive Details</h2>
          <dl>
            {railItems.map(([term, detail]) => (
              <div>
                <dt>{term}</dt>
                <dd>{detail}</dd>
              </div>
            ))}
          </dl>
        </section>

        <section class="rail-card related-card">
          <h2>Related Records</h2>
          <ul>
            <li><a href="/mission">Mission Framework</a></li>
            <li><a href="/ship">Ship Profile</a></li>
            <li><a href="/logs">Operational Logs</a></li>
          </ul>
        </section>
      </aside>
    </div>
  </main>
</Layout>