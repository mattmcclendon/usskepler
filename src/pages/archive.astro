---
import Layout from "../layouts/layout.astro";

const archiveCards = [
  {
    label: "VESSEL\nRECORD",
    title: "USS Kepler",
    body: "Registry, lineage, command structure, deployment record, and operational role within Frontier Squadron One.",
    accent: "operations",
    href: "/archive/uss-kepler",
  },
  {
    label: "STRATEGIC\nDIRECTIVE",
    title: "Frontier Initiative",
    body: "The Federation program behind Kepler's mission of sustained presence, civic support, and long-term trust.",
    accent: "command",
    href: "/archive/the-frontier-initiative",
  },
  {
    label: "VESSEL\nDOCTRINE",
    title: "Doctrine",
    body: "The operating philosophy that guides Kepler's work with frontier communities and member worlds.",
    accent: "operations",
    href: "/archive/doctrine",
  },
  {
    label: "CREW\nMANIFEST",
    title: "Senior Staff",
    body: "Personnel records, departmental assignments, and log access for the officers and specialists aboard Kepler.",
    accent: "sciences",
    href: "/crew",
  },
  {
    label: "FIELD\nLOGS",
    title: "Senior Staff Logs",
    body: "Personal records from command, sciences, operations, diplomacy, medicine, and shipboard life.",
    accent: "operations",
    href: "/logs/commanding-officer",
  },
  {
    label: "CHRONOLOGY\nINDEX",
    title: "Timeline",
    body: "A chronological record of Kepler's construction, crew assembly, launch, and Frontier Initiative service.",
    accent: "command",
    href: "/timeline",
  },
];

const railItems = [
  ["Section", "Archive"],
  ["Maintained By", "UFP Office of Cultural & Scientific Archives"],
  ["Location", "Memory Alpha"],
  ["Primary Vessel", "USS Kepler NCC-83639"],
  ["Program", "Frontier Initiative"],
  ["Status", "Active"],
  ["Access", "Public"],
];
---

<Layout title="Archive" current="archive">
  <main class="interior-shell">
    <section class="page-hero">
      <p class="eyebrow">Memory Alpha</p>
      <h1>Archive</h1>
      <p class="dek">
        Doctrine, vessel records, personnel files, logs, and historical materials related to USS Kepler and the Frontier Initiative.
      </p>
    </section>

    <div class="content-layout">
      <article class="main-content">
        <section class="prose-block archive-overview">
          <h2>Overview</h2>
          <p>
            The Archive organizes the records that explain USS Kepler as a vessel, a crew,
            and a mission platform. It is not a replacement for the main Mission, Ship,
            Crew, or Logs sections. It is the supporting record beneath them.
          </p>
          <p>
            Readers looking for orientation should begin with the mission framework,
            vessel record, crew manifest, and senior staff logs. Additional records will
            expand as Kepler's operational history develops.
          </p>
        </section>

        <section class="marginalia-image">
          <img
            src="/images/shared/kepler-drydock.png"
            alt="USS Kepler construction drydock"
            class="marginalia"
          />
        </section>

        <section class="archive-grid two-column">
          {archiveCards.map((card) => (
            <a class={`archive-card ${card.accent}`} href={card.href}>
              <p class="card-label">{card.label}</p>
              <h2>{card.title}</h2>
              <p>{card.body}</p>
              <span class="card-action">Open Record</span>
            </a>
          ))}
        </section>

        <section class="prose-block section-note">
          <h2>Archive Principle</h2>
          <p>
            The purpose of an archive is not simply preservation. It is continuity.
            Records allow institutions, crews, and communities to learn from what came before,
            notice what is changing, and remember why the work began.
          </p>
        </section>
      </article>

      <aside class="context-rail">
        <section class="rail-card">
          <h2>Records Hub</h2>
          <p>
            The Archive provides structured access to the records that support Kepler's mission, crew, doctrine, and operational history.
          </p>
        </section>

        <section class="rail-card metadata-card">
          <h2>Archive Summary</h2>
          <dl>
            {railItems.map(([term, detail]) => (
              <div>
                <dt>{term}</dt>
                <dd>{detail}</dd>
              </div>
            ))}
          </dl>
        </section>

        <section class="rail-card related-card">
          <h2>Related Records</h2>
          <ul>
            <li><a href="/mission">Mission</a></li>
            <li><a href="/ship">Ship</a></li>
            <li><a href="/crew">Crew</a></li>
            <li><a href="/logs/commanding-officer">Commanding Officer Logs</a></li>
            <li><a href="/archive/uss-kepler">Vessel Profile</a></li>
          </ul>
        </section>
      </aside>
    </div>
  </main>
</Layout>
<style>
  .archive-overview {
    max-width: 66ch;
  }

  .marginalia-image {
    margin: 1.25rem 0 2rem;
  }

  .marginalia-image img {
  display: block;
  width: min(100%, 540px);
  height: auto;
  margin-left: auto;
  }

  @media (max-width: 760px) {
  }
</style>