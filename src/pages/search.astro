

---
import Layout from "../layouts/layout.astro";
---

<Layout title="Search" current="search">
  <main class="interior-shell">
    <section class="page-hero">
      <p class="eyebrow">Archive Services</p>
      <h1>Search</h1>
      <p class="dek">
        Full archive search is currently under development.
      </p>
    </section>

    <section class="coming-soon">
      <h2>Coming Soon</h2>
      <p>
        USS Kepler will eventually include a full-text archive search powered by
        Pagefind, allowing visitors to search doctrine, mission reports,
        personnel records, logs, and reference documents.
      </p>
    </section>
  </main>
</Layout>

<style>
  .interior-shell {
    padding: 3rem 3.2vw 4rem;
  }

  .page-hero {
    max-width: 820px;
    margin-bottom: 2.5rem;
    padding-bottom: 1.6rem;
    border-bottom: 1px solid var(--line);
  }

  .eyebrow {
    margin: 0 0 1.1rem;
    color: var(--command);
    font-family: "Orbitron", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: "Orbitron", sans-serif;
    font-size: clamp(2.4rem, 4.2vw, 4.4rem);
    line-height: 1;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dek {
    max-width: 680px;
    margin: 1rem 0 0;
    font-family: "Crimson Text", serif;
    font-size: clamp(1.2rem, 1.45vw, 1.45rem);
    line-height: 1.34;
  }

  .coming-soon {
    max-width: 720px;
    padding: 1.5rem;
    background: var(--paper-deep);
    border-left: 4px solid var(--operations);
  }

  .coming-soon h2 {
    margin: 0 0 0.75rem;
    color: var(--operations);
    font-family: "Orbitron", sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .coming-soon p {
    margin: 0;
    font-family: "Crimson Text", serif;
    font-size: 1.2rem;
    line-height: 1.5;
  }
</style>