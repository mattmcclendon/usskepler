---
import Layout from "../layouts/layout.astro";
---

<Layout title="Search" current="search">
  <main class="interior-shell">
    <section class="page-hero">
      <p class="eyebrow">Archive Access</p>
      <h1>Search</h1>
      <p class="dek">
        Full archive search is currently under development and will be available in a future update.
      </p>
    </section>

    <section class="coming-soon">
      <h2>Coming Soon</h2>
      <p>
        USS Kepler will eventually include a full-text archive search powered by
        Pagefind, allowing visitors to search doctrine, mission reports,
        personnel records, logs, and reference documents.
      </p>
    </section>
  </main>
</Layout>

<style>
  .coming-soon {
    max-width: 66ch;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.28);
    border-left: 4px solid var(--operations);
  }

  .coming-soon h2 {
    margin: 0 0 0.75rem;
    color: var(--operations);
    font-family: "Orbitron", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .coming-soon p {
    margin: 0;
  }
</style>