---
import Layout from "../layouts/layout.astro";

const timeline = [
  // existing timeline data array content here
];

const railItems = [
  ["Section", "Timeline"],
  ["Focus", "Archive Chronology"],
  ["Scope", "Federation / Frontier Initiative / USS Kepler"],
  ["Format", "Chronological Record"],
  ["Archive Status", "Active"],
];
---

<Layout title="Timeline" current="archive">
  <main class="interior-shell">
    <section class="page-hero" aria-labelledby="page-title">
      <p class="eyebrow">Archive Chronology</p>
      <h1 id="page-title">Timeline</h1>
      <p class="dek">
        A chronological record of the historical conditions, planning decisions,
        and operational milestones that shaped USS Kepler and the Frontier
        Initiative.
      </p>
    </section>

    <div class="content-layout">
      <article class="main-content">

      <!-- existing timeline content here -->

      </article>

      <aside class="context-rail" aria-label="Timeline metadata">
        <section class="rail-card signature-card">
          <p class="rail-kicker">Chronology Record</p>
          <h2>USS Kepler</h2>
          <p>
            Timeline is the archive’s chronological layer: the historical record
            that connects Federation context, Frontier Initiative planning, and
            Kepler’s operational mandate.
          </p>
        </section>

        <section class="rail-card metadata-card">
          <h2>Archive Details</h2>
          <dl>
            {railItems.map(([term, detail]) => (
              <div>
                <dt>{term}</dt>
                <dd>{detail}</dd>
              </div>
            ))}
          </dl>
        </section>

        <section class="rail-card related-card">
          <h2>Related Records</h2>
          <ul>
            <li><a href="/mission">Mission Overview</a></li>
            <li><a href="/archive/frontier-initiative">Frontier Initiative</a></li>
            <li><a href="/archive/kepler-doctrine">USS Kepler Doctrine</a></li>
          </ul>
        </section>
      </aside>
    </div>
  </main>
</Layout>

<style>
/* Deleted .timeline-shell, .timeline-hero, .timeline-hero h1, .timeline-hero p:not(.eyebrow) CSS rules */

/* Deleted .eyebrow rule if it existed in timeline.astro */

/* Updated .timeline-map rule */
.timeline-map {
  display: grid;
  gap: clamp(2.25rem, 5vw, 3.75rem);
}

/* .timeline-era remains unchanged */
.timeline-era {
  display: grid;
  grid-template-columns: minmax(150px, 240px) minmax(0, 1fr);
  gap: clamp(2rem, 5vw, 3.5rem);
}

/* Updated .era-events::before rule */
.era-events::before {
  position: absolute;
  top: 0.4rem;
  bottom: 0.4rem;
  left: 0.35rem;
  width: 1px;
  content: "";
  background: linear-gradient(180deg, rgba(167, 19, 19, 0.45), rgba(43, 83, 167, 0.18));
}

/* Updated .timeline-event::before rule */
.timeline-event::before {
  position: absolute;
  top: 0.55rem;
  left: -1.15rem;
  width: 0.66rem;
  height: 0.66rem;
  box-sizing: border-box;
  content: "";
  background: var(--paper);
  border: 2px solid var(--command);
  border-radius: 999px;
  box-shadow: 0 0 0 4px rgba(167, 19, 19, 0.08);
  transform: translateX(-50%);
}

@media (max-width: 620px) {
  .timeline-event::before {
    left: -0.75rem;
  }
}
</style>