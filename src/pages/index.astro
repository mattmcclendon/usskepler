---
import Layout from "../layouts/layout.astro";

const featuredDocuments = [
  {
    featured: true,
    type: "FRONTIER\nINITIATIVE",
    title: "Mission of Support",
    description:
      "A long-term Federation commitment to strengthening frontier communities through partnership, capability building, sustained presence, and civic trust.",
    accent: "command",
    href: "/mission",
  },
  {
    type: "SHIP\nPROFILE",
    title: "USS Kepler",
    description:
      "The Sagan-class vessel assigned to carry the Frontier Initiative into practice.",
    accent: "command",
    href: "/ship",
  },
  {
    type: "CREW\nMANIFEST",
    title: "Senior Staff",
    description:
      "The officers, specialists, and families giving shape to Kepler's mission.",
    accent: "sciences",
    href: "/crew",
  },
  {
    type: "COMMAND\nLOGS",
    title: "Captain's Logs",
    description:
      "Personal records from command, senior staff, and the evolving life of the ship.",
    accent: "command",
    href: "/logs/commanding-officer",
  },
  {
    type: "ARCHIVE\nRECORDS",
    title: "Archive",
    description:
      "Doctrine, vessel records, mission materials, and supporting documents.",
    accent: "operations",
    href: "/archive",
  },
];

const quickAccess = [
  ["Understand the Mission", "/mission"],
  ["Explore USS Kepler", "/ship"],
  ["Meet the Crew", "/crew"],
  ["Read the Logs", "/logs/commanding-officer"],
  ["Browse the Archives", "/archive"],
  ["Follow the Timeline", "/timeline"],
];
---

<Layout title="USS Kepler | Frontier Initiative Service Vessel">
  <main>
        <section class="hero" aria-labelledby="hero-title">
          <img
            src="/kepler-hero-image-index.png"
            alt="USS Kepler in orbit above a Federation world"
            class="hero-bg"
          />
          <div class="hero-shade"></div>

          <div class="hero-content">
            <p class="eyebrow">A Federation starship. A mission of support.</p>
            <h1 id="hero-title">
              <span>The Frontier</span>
              <span>is Belonging</span>
            </h1>
            <div class="hero-rule"></div>
            <p class="hero-copy">
              The USS Kepler is a Sagan-class starship assigned to the Frontier
              Initiative, supporting Federation member worlds, settlements, and
              frontier communities by strengthening the connections between
              people, institutions, and shared civic life.
            </p>
            <div class="hero-actions">
              <a href="/about-the-project" class="button primary">Explore the Project</a>
              <a href="/crew" class="button secondary">Meet the Crew</a>
            </div>
          </div>
        </section>

        <section class="content-grid" aria-labelledby="featured-title">
          <div class="featured-documents">
            <div class="section-heading">
              <h2 id="featured-title">Where to Start</h2>
            </div>

            <div class="document-row">
              {featuredDocuments.map((document) => (
                <a class={`document-card ${document.accent} ${document.featured ? 'featured' : ''}`} href={document.href}>
                  <p class="document-type">{document.type}</p>
                  <h3>{document.title}</h3>
                  <p>{document.description}</p>
                  <div class="document-footer">
                    <span>Learn More</span>
                    <span aria-hidden="true">›</span>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <aside class="archive-panel" aria-labelledby="quick-access-title">
            <section class="quick-access" aria-labelledby="quick-access-title">
              <h2 id="quick-access-title">Quick Access</h2>
              <ul>
                {quickAccess.map(([item, href]) => (
                  <li>
                    <a href={href}>
                      <span>{item}</span>
                      <span aria-hidden="true">›</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          </aside>
        </section>
  </main>
</Layout>

<style>

  .hero {
    position: relative;
    min-height: 470px;
    overflow: hidden;
    background: var(--space);
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 52% 50%;
    filter: brightness(1.02) contrast(1.08) saturate(1.04);
    transform: translateZ(0);
    z-index: 0;
  }

  .hero-shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse at 70% 42%, rgba(5, 8, 12, 0) 0%, rgba(5, 8, 12, 0) 26%, rgba(5, 8, 12, 0.09) 58%, rgba(5, 8, 12, 0.26) 100%),
      radial-gradient(ellipse at 70% 42%, rgba(120, 190, 230, 0.10) 0%, rgba(120, 190, 230, 0.04) 20%, rgba(120, 190, 230, 0) 44%),
      linear-gradient(90deg, rgba(5, 8, 12, 0.86) 0%, rgba(5, 8, 12, 0.64) 34%, rgba(5, 8, 12, 0.035) 68%, rgba(5, 8, 12, 0) 100%),
      linear-gradient(0deg, rgba(5, 8, 12, 0.08), rgba(5, 8, 12, 0.08));
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 620px;
    padding: 4.2rem 3.2vw 3.4rem;
    color: #ffffff;
  }

  .eyebrow {
    margin: 0 0 1.3rem;
    color: var(--operations);
    font-family: "Orbitron", sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: "Inter", sans-serif;
    text-transform: uppercase;
    max-width: 560px;
    font-size: clamp(3rem, 4.6vw, 4.75rem);
    line-height: 1.1;
    font-weight: 500;
    letter-spacing: 0.015em;
  }

  h1 span {
    display: block;
  }

  .hero-rule {
    width: 54px;
    height: 1px;
    margin: 1.8rem 0 1.4rem;
    background: rgba(255, 255, 255, 0.72);
  }

  .hero-copy {
    max-width: 520px;
    margin: 0;
    color: rgba(255, 255, 255, 0.88);
    font-family: "Crimson Text", serif;
    font-size: clamp(1.15rem, 1.45vw, 1.45rem);
    line-height: 1.38;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.8rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.85rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.72);
    font-family: "Orbitron", sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .button.primary {
    background: rgba(255, 255, 255, 0.08);
  }

  .button.secondary {
    border-color: rgba(214, 164, 68, 0.78);
    color: #f0d6a2;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 352px);
    gap: 3.2vw;
    padding: 1.9rem 3.2vw 1.35rem;
    background: var(--paper);
    position: relative;
    z-index: 3;
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1.05rem;
  }

  .section-heading h2,
  .archive-panel h2 {
    margin: 0;
    color: var(--sciences);
    font-family: "Orbitron", sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .section-heading a,
  .notice-card a {
    color: #6d5522;
    font-family: "Orbitron", sans-serif;
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .document-row {
    display: grid;
    grid-template-columns: minmax(280px, 1.45fr) repeat(2, minmax(160px, 1fr));
    gap: 0.72rem;
  }

  .document-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 156px;
    padding: 1.05rem 1rem 0.95rem;
    color: inherit;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.28);
    border: 1px solid var(--line);
    border-left: 3px solid var(--operations);
  }
  .document-card:hover {
    background: rgba(255, 255, 255, 0.4);
  }

  .document-card.command {
    border-left-color: var(--command);
  }

  .document-card.operations {
    border-left-color: var(--operations);
  }

  .document-card.sciences {
    border-left-color: var(--sciences);
  }

  .document-card.featured {
    grid-row: span 2;
    min-height: 324px;
    background: rgba(255, 255, 255, 0.42);
  }

  .document-card.featured h3 {
    font-size: clamp(2rem, 2.6vw, 2.8rem);
    line-height: 1;
  }

  .document-card.featured p:not(.document-type) {
    max-width: 36ch;
    font-size: 1.1rem;
    line-height: 1.36;
  }

  .document-type {
    min-height: 2.2em;
    margin: 0 0 0.9rem;
    color: var(--operations);
    font-family: "Orbitron", sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: pre-line;
  }

  .document-card.command .document-type {
    color: var(--command);
  }

  .document-card.operations .document-type {
    color: var(--operations);
  }

  .document-card.sciences .document-type {
    color: var(--sciences);
  }

  .document-card h3 {
    margin: 0 0 0.55rem;
    font-family: "Crimson Text", serif;
    font-size: clamp(1.35rem, 1.6vw, 1.7rem);
    line-height: 1.05;
    font-weight: 600;
  }

  .document-card p:not(.document-type) {
    margin: 0;
    color: #1c1a17;
    font-family: "Crimson Text", serif;
    font-size: 1rem;
    line-height: 1.3;
  }

  .document-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 1.1rem;
    font-family: "Crimson Text", serif;
    font-size: 0.95rem;
  }

  .document-footer span:last-child {
    color: var(--command);
    font-size: 1.7rem;
    line-height: 1;
  }

  .archive-panel {
    display: grid;
    align-content: start;
    gap: 0;
  }


  .quick-access ul {
    margin: 0.8rem 0 0;
    padding: 0;
    list-style: none;
    border: 1px solid var(--line);
  }

  .quick-access li + li {
    border-top: 1px solid var(--line);
  }

  .quick-access a {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    min-height: 42px;
    padding: 0.62rem 0.75rem;
    color: #25221d;
    font-family: "Crimson Text", serif;
    font-size: 1.02rem;
  }


  @media (max-width: 1180px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    .document-row {
      grid-template-columns: repeat(2, minmax(220px, 1fr));
    }

    .document-card.featured {
      grid-row: auto;
    }
  }

  @media (max-width: 720px) {
    .hero {
      min-height: 560px;
    }

    .hero-content {
      padding: 3.2rem 1rem 2.5rem;
    }

    .content-grid {
      padding: 1.4rem 1rem;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .document-row {
      grid-template-columns: 1fr;
    }
  }
</style>