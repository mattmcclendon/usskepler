---
const title = "U.S.S. KEPLER";
const subtitle = "A STAR TREK™ FAN GROUP";
const contact = "info@usskepler.org";
const titleSize = "4rem";
const subtitleSize = "2rem";
const contactSize = "1.5rem";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>USS Kepler</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Orbitron:wght@500;600;700&display=swap" rel="stylesheet">
  </head>

  <body>
    <main class="hero">
      <div class="hero-stage">
        <img
          src="/kepler-bg-planet.png"
          alt="Planet horizon in space"
          class="hero-bg"
        />

        <div class="hero-overlay">
          <img
            src="/kepler-combadge.png"
            alt="USS Kepler insignia"
            class="hero-badge"
          />

          <h1 style={`--title-size: ${titleSize};`}>{title}</h1>
          <p class="subtitle" style={`--subtitle-size: ${subtitleSize};`}>
            {subtitle}
          </p>

          <p class="contact" style={`--contact-size: ${contactSize};`}>
            <a href={`mailto:${contact}`}>{contact}</a>
          </p>
        </div>
      </div>
    </main>
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #000;
    width: 100%;
    min-height: 100%;
  }

  body {
    min-height: 100vh;
  }

  .hero {
    min-height: 100vh;
    display: grid;
    place-items: center;
    background: #000;
    overflow: hidden;
  }

  .hero-stage {
    position: relative;
    width: min(100vw, calc(100vh * 1.7777778));
    aspect-ratio: 16 / 9;
    background: #000;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;

    /* preserve full composition instead of cropping */
    object-fit: contain;

    /* bias the planet slightly upward to match composition */
    object-position: center 42%;

    /* ensure empty space blends seamlessly */
    background: #000;

    /* subtle scale for visual balance */
    transform: scale(0.98);

    /* tone control so text reads cleanly */
    filter: brightness(0.8) contrast(1.05);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    color: #ffffff;
    text-align: center;
  }

  .hero-badge {
    position: absolute;
    left: 50%;
    top: 41.8%;
    transform: translate(-50%, -50%);
    width: clamp(88px, 7.25vw, 128px);
    height: auto;
  }

  h1 {
    position: absolute;
    left: 50%;
    top: 59.8%;
    transform: translate(-50%, -50%);
    margin: 0;
    width: 100%;
    font-family: "Orbitron", sans-serif;
    font-size: clamp(2.3rem, 3.6vw, var(--title-size));
    line-height: 0.95;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .subtitle {
    position: absolute;
    left: 50%;
    top: 71.1%;
    transform: translate(-50%, -50%);
    margin: 0;
    width: 100%;
    font-family: "Orbitron", sans-serif;
    font-size: clamp(1rem, 1.8vw, var(--subtitle-size));
    line-height: 1;
    font-weight: 500;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .contact {
    position: absolute;
    left: 50%;
    top: 86.5%;
    transform: translate(-50%, -50%);
    margin: 0;
    width: 100%;
    font-family: "Inter", sans-serif;
    font-size: clamp(0.95rem, 1.3vw, var(--contact-size));
    line-height: 1;
    font-weight: 400;
    letter-spacing: 0.08em;
  }

  .contact a {
    color: inherit;
    text-decoration: none;
  }

  .contact a:hover {
    opacity: 0.85;
  }

  @media (max-width: 900px) {
    .hero-stage {
      width: 100vw;
      height: 100vh;
      aspect-ratio: auto;
    }

    .hero-bg {
      object-fit: cover;
      object-position: center center;
      transform: scale(1.08);
    }

    .hero-badge {
      top: 41%;
      width: clamp(84px, 18vw, 132px);
    }

    h1 {
      top: 57.5%;
      font-size: clamp(2rem, 8vw, 3.1rem);
      letter-spacing: 0.12em;
      padding: 0 1rem;
      box-sizing: border-box;
    }

    .subtitle {
      top: 66.5%;
      font-size: clamp(0.95rem, 3.6vw, 1.5rem);
      letter-spacing: 0.09em;
      padding: 0 1rem;
      box-sizing: border-box;
    }

    .contact {
      top: 79.5%;
      font-size: clamp(0.9rem, 3.2vw, 1.15rem);
      padding: 0 1rem;
      box-sizing: border-box;
    }
  }
</style>
