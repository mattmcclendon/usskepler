---
import Layout from "../layouts/layout.astro";

const featuredDocuments = [
  {
    type: "STRATEGIC\nDIRECTIVE",
    title: "The Frontier Initiative",
    description:
      "A strategic framework for distributed capability, settlement resilience, and Federation renewal.",
    stardate: "80452.200",
    accent: "command",
    href: "/archive/the-frontier-initiative",
  },
  {
    type: "DEVELOPMENT\nFRAMEWORK",
    title: "The Settlement Continuum",
    description:
      "A framework for understanding community development, resilience, and institutional partnership across Federation space.",
    stardate: "79546.803",
    accent: "sciences",
    href: "/archive/settlement-continuum",
  },
  {
    type: "STRATEGIC\nASSESSMENT",
    title: "State of the Federation, 2403",
    description:
      "An historical assessment of the Federation Renaissance and the post-Frontier Day era.",
    stardate: "79859.246",
    accent: "operations",
    href: "/archive/state-of-the-federation-2403",
  },
  {
    type: "FOUNDATIONAL\nDOCTRINE",
    title: "The Kepler Doctrine",
    description:
      "The operating philosophy of USS Kepler and the Frontier Initiative.",
    stardate: "80782.420",
    accent: "operations",
    href: "/archive/doctrine",
  },
  {
    type: "COMMANDING\nOFFICER LOG",
    title: "Captain's Log 78782.306",
    description:
      "Assignment to USS Kepler and preliminary Frontier Initiative preparations six months after Frontier Day.",
    stardate: "78782.306",
    accent: "command",
    href: "/logs/commanding-officer/78782-306",
  },
  {
    type: "ARCHIVE\nCHRONOLOGY",
    title: "Timeline",
    description:
      "Selected events related to USS Kepler, the Frontier Initiative, and the Federation Renaissance.",
    stardate: "80790.000",
    accent: "sciences",
    href: "/timeline",
  },
];

const quickAccess = [
  ["Read the Doctrine", "/archive/doctrine"],
  ["The Frontier Initiative", "/archive/the-frontier-initiative"],
  ["State of the Federation", "/archive/state-of-the-federation-2403"],
  ["Commanding Officer Logs", "/logs/commanding-officer/78782-306"],
  ["Settlement Profiles", "/archive"],
  ["Timeline", "/timeline"],
];
---

<Layout title="USS Kepler | Frontier Initiative Service Vessel">
  <main>
        <section class="hero" aria-labelledby="hero-title">
          <img
            src="/kepler-hero-image-index.png"
            alt="USS Kepler in orbit above a Federation world"
            class="hero-bg"
          />
          <div class="hero-shade"></div>

          <div class="hero-content">
            <p class="eyebrow">A Federation starship. A mission of support.</p>
            <h1 id="hero-title">
              <span>The Frontier</span>
              <span>is Belonging</span>
            </h1>
            <div class="hero-rule"></div>
            <p class="hero-copy">
              The USS Kepler is a Sagan-class starship assigned to the Frontier
              Initiative, supporting Federation member worlds, settlements, and
              frontier communities by strengthening the connections between
              people, institutions, and shared civic life.
            </p>
            <div class="hero-actions">
              <a href="/about-the-project" class="button primary">Explore the Project</a>
              <a href="/archive/doctrine" class="button secondary">Read the Doctrine</a>
            </div>
          </div>
        </section>

        <section class="content-grid" aria-labelledby="featured-title">
          <div class="featured-documents">
            <div class="section-heading">
              <h2 id="featured-title">Featured Documents</h2>
              <a href="/archive">View All Documents</a>
            </div>

            <div class="document-row">
              {featuredDocuments.map((document) => (
                <a class={`document-card ${document.accent}`} href={document.href}>
                  <p class="document-type">{document.type}</p>
                  <h3>{document.title}</h3>
                  <p>{document.description}</p>
                  <div class="document-footer">
                    <span>{document.stardate}</span>
                    <span aria-hidden="true">›</span>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <aside class="archive-panel" aria-labelledby="notice-title">
            <section class="notice-card">
              <div class="notice-icon" aria-hidden="true"><span>!</span></div>
              <div>
                <h2 id="notice-title">Archive Notice</h2>
                <p>
                  This site is an independent Star Trek fan project documenting
                  the fictional operations, doctrine, and civic mission of USS
                  Kepler. Materials are presented as an in-universe archive.
                </p>
                <a href="/disclaimer">Learn More</a>
              </div>
            </section>

            <section class="quick-access" aria-labelledby="quick-access-title">
              <h2 id="quick-access-title">Quick Access</h2>
              <ul>
                {quickAccess.map(([item, href]) => (
                  <li>
                    <a href={href}>
                      <span>{item}</span>
                      <span aria-hidden="true">›</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          </aside>
        </section>
  </main>
</Layout>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    min-height: 100%;
    background: #0b1116;
    color: #111111;
  }

  :root {
    --paper: #f4efe4;
    --paper-deep: #e5ddce;
    --ink: #111111;
    --muted: #6d665c;
    --space: #080d12;
    --command: #a71313;
    --operations: #d6a444;
    --sciences: #2b53a7;
    --line: rgba(17, 17, 17, 0.16);
  }

  body {
    font-family: "Inter", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .page-shell {
    position: relative;
    min-height: 100vh;
    padding-left: 48px;
    background: var(--paper);
  }

  .side-rail {
    position: fixed;
    inset: 0 auto 0 0;
    z-index: 20;
    width: 48px;
    background: #101820;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.78);
  }


  .rail-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-90deg);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    white-space: nowrap;
  }


  .site-header {
    position: relative;
    z-index: 4;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(2rem, 5vw, 5.5rem);
    align-items: center;
    min-height: 118px;
    padding: 2rem 3.2vw 1.25rem;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
  }

  .brand {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    font-family: "Orbitron", sans-serif;
    line-height: 1;
    color: var(--ink);
  }

  .brand-line {
    display: inline-flex;
    align-items: baseline;
    gap: 1rem;
  }

  .brand-name {
    display: block;
    font-size: clamp(1.6rem, 2.6vw, 2.6rem);
    font-weight: 500;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .registry {
    display: block;
    font-size: clamp(0.8rem, 1.2vw, 1.2rem);
    font-weight: 500;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .affiliation {
    display: block;
    font-family: "Crimson Text", serif;
    font-size: clamp(0.95rem, 1.15vw, 1.12rem);
    font-style: italic;
    letter-spacing: 0.18em;
    white-space: nowrap; 
    margin-top: 7px;
  }

  .main-nav {
    display: flex;
    gap: clamp(1.2rem, 3vw, 3.2rem);
    justify-content: end;
    align-items: center;
    padding-bottom: 0.15rem;
    font-family: "Orbitron", sans-serif;
    font-size: 0.86rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .main-nav a {
    position: relative;
    padding-bottom: 1.1rem;
  }

  .search-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.15rem;
    height: 1.15rem;
    padding-bottom: 1.1rem;
  }

  .search-icon {
    display: block;
    width: 1.05rem;
    height: 1.05rem;
    background: currentColor;
    mask: url("/search.svg") center / contain no-repeat;
    -webkit-mask: url("/search.svg") center / contain no-repeat;
  }

  .main-nav a::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 3px;
    pointer-events: none;
    content: "";
    background: var(--operations);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 180ms ease;
  }

  .search-link::after {
    bottom: -1.1rem;
  }

  .main-nav a:nth-child(1)::after,
  .main-nav a:nth-child(4)::after {
    background: var(--command);
  }

  .main-nav a:nth-child(2)::after,
  .main-nav a:nth-child(5)::after {
    background: var(--sciences);
  }

  .main-nav a:hover::after {
    transform: scaleX(1);
  }

  .hero {
    position: relative;
    min-height: 470px;
    overflow: hidden;
    background: var(--space);
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 50%;
    filter: brightness(0.9) contrast(1.12) saturate(1.04);
    z-index: 0;
  }

  .hero-shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse at 68% 43%, rgba(105, 160, 190, 0) 0%, rgba(105, 160, 190, 0) 24%, rgba(5, 8, 12, 0.18) 58%, rgba(5, 8, 12, 0.34) 100%),
      radial-gradient(ellipse at 67% 43%, rgba(120, 190, 230, 0.16) 0%, rgba(120, 190, 230, 0.07) 22%, rgba(120, 190, 230, 0) 48%),
      linear-gradient(90deg, rgba(5, 8, 12, 0.92) 0%, rgba(5, 8, 12, 0.72) 34%, rgba(5, 8, 12, 0.10) 78%),
      linear-gradient(0deg, rgba(5, 8, 12, 0.22), rgba(5, 8, 12, 0.22));
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 620px;
    padding: 4.2rem 3.2vw 3.4rem;
    color: #ffffff;
  }

  .eyebrow {
    margin: 0 0 1.3rem;
    color: var(--operations);
    font-family: "Orbitron", sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: "Inter", sans-serif;
    text-transform: uppercase;
    max-width: 560px;
    font-size: clamp(3rem, 4.6vw, 4.75rem);
    line-height: 1.1;
    font-weight: 500;
    letter-spacing: 0.015em;
  }

  h1 span {
    display: block;
  }

  .hero-rule {
    width: 54px;
    height: 1px;
    margin: 1.8rem 0 1.4rem;
    background: rgba(255, 255, 255, 0.72);
  }

  .hero-copy {
    max-width: 520px;
    margin: 0;
    color: rgba(255, 255, 255, 0.88);
    font-family: "Crimson Text", serif;
    font-size: clamp(1.15rem, 1.45vw, 1.45rem);
    line-height: 1.38;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.8rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.85rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.72);
    font-family: "Orbitron", sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .button.primary {
    background: rgba(255, 255, 255, 0.08);
  }

  .button.secondary {
    border-color: rgba(214, 164, 68, 0.78);
    color: #f0d6a2;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 352px);
    gap: 3.2vw;
    padding: 1.9rem 3.2vw 1.35rem;
    background: var(--paper);
    position: relative;
    z-index: 3;
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1.05rem;
  }

  .section-heading h2,
  .archive-panel h2 {
    margin: 0;
    color: var(--sciences);
    font-family: "Orbitron", sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .section-heading a,
  .notice-card a {
    color: #6d5522;
    font-family: "Orbitron", sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .document-row {
    display: grid;
    grid-template-columns: repeat(5, minmax(150px, 1fr));
    gap: 0.72rem;
  }

  .document-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 276px;
    padding: 1.05rem 1rem 0.95rem;
    background: rgba(255, 255, 255, 0.28);
    border: 1px solid var(--line);
    border-left: 3px solid var(--operations);
  }
  .document-card:hover {
    background: rgba(255, 255, 255, 0.4);
  }

  .document-card.command {
    border-left-color: var(--command);
  }

  .document-card.sciences {
    border-left-color: var(--sciences);
  }

  .document-type {
    min-height: 2.2em;
    margin: 0 0 1.25rem;
    color: var(--operations);
    font-family: "Orbitron", sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: pre-line;
  }

  .document-card.command .document-type {
    color: var(--command);
  }

  .document-card.sciences .document-type {
    color: var(--sciences);
  }

  .document-card h3 {
    margin: 0 0 0.85rem;
    font-family: "Crimson Text", serif;
    font-size: clamp(1.35rem, 1.6vw, 1.7rem);
    line-height: 1.05;
    font-weight: 600;
  }

  .document-card p:not(.document-type) {
    margin: 0;
    color: #1c1a17;
    font-family: "Crimson Text", serif;
    font-size: 1rem;
    line-height: 1.36;
  }

  .document-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 1.1rem;
    font-family: "Crimson Text", serif;
    font-size: 0.95rem;
  }

  .document-footer span:last-child {
    color: var(--command);
    font-size: 1.7rem;
    line-height: 1;
  }

  .archive-panel {
    display: grid;
    align-content: start;
    gap: 1.25rem;
  }

  .notice-card {
    display: grid;
    grid-template-columns: 46px 1fr;
    gap: 1rem;
    padding: 1.1rem;
    background: var(--paper-deep);
    border: 1px solid var(--line);
  }

  .notice-icon {
    position: relative;
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    color: #8f6c21;
    font-family: "Orbitron", sans-serif;
    font-weight: 700;
  }

  .notice-icon::before {
    position: absolute;
    inset: 0;
    content: "";
    border: 2px solid var(--operations);
    transform: rotate(45deg);
  }

  .notice-icon span {
    position: relative;
    z-index: 1;
    display: block;
    line-height: 1;
  }

  .notice-card h2 {
    color: #8b6110;
  }

  .notice-card p {
    margin: 0.8rem 0 0.9rem;
    color: #2b261f;
    font-family: "Crimson Text", serif;
    font-size: 1rem;
    line-height: 1.35;
  }

  .quick-access ul {
    margin: 0.8rem 0 0;
    padding: 0;
    list-style: none;
    border: 1px solid var(--line);
  }

  .quick-access li + li {
    border-top: 1px solid var(--line);
  }

  .quick-access a {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    min-height: 36px;
    padding: 0.5rem 0.75rem;
    color: #25221d;
    font-family: "Crimson Text", serif;
    font-size: 1rem;
  }

  .site-footer {
    display: grid;
    grid-template-columns: 72px minmax(260px, 1fr) minmax(280px, 0.8fr);
    grid-template-areas:
      "emblem summary legal"
      "emblem nav legal";
    gap: 0.85rem 2.4rem;
    align-items: center;
    padding: 2.1rem 3.2vw;
    background: #101820;
    min-height: 132px;
    color: rgba(255, 255, 255, 0.78);
  }

  .footer-emblem {
    grid-area: emblem;
    display: block;
    width: 64px;
    height: 64px;
    object-fit: contain;
    opacity: 0.82;
  }

  .site-footer p {
    grid-area: summary;
    max-width: 520px;
    margin: 0;
    font-family: "Crimson Text", serif;
    font-size: 0.95rem;
    line-height: 1.35;
  }

  .site-footer nav {
    grid-area: nav;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.2rem;
    font-family: "Orbitron", sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .site-footer .legal {
    grid-area: legal;
    justify-self: end;
    max-width: 480px;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.66);
  }

  @media (max-width: 1180px) {
    .site-header {
      grid-template-columns: 1fr;
      align-items: start;
      position: relative;
      z-index: 4;
    }

    .main-nav {
      flex-wrap: wrap;
    }

    .content-grid {
      grid-template-columns: 1fr;
    }

    .document-row {
      grid-template-columns: repeat(2, minmax(180px, 1fr));
    }

    .site-footer {
      grid-template-columns: 56px 1fr;
      grid-template-areas:
        "emblem summary"
        "emblem nav"
        "legal legal";
      position: relative;
      z-index: 3;
    }

    .site-footer .legal {
      justify-self: start;
      max-width: 720px;
    }
  }

  @media (max-width: 720px) {
    .page-shell {
      padding-left: 0;
    }

    .side-rail {
      display: none;
    }

    .site-header {
      min-height: auto;
      padding: 1.4rem 1rem 1rem;
    }


    .brand-name {
      font-size: 1.5rem;
    }

    .registry {
      font-size: 1.0rem;
    }

    .main-nav {
      gap: 0.9rem 1.1rem;
      font-size: 0.72rem;
      letter-spacing: 0.16em;
    }

    .main-nav a {
      padding-bottom: 0.45rem;
    }
    .search-link {
      padding-bottom: 0.45rem;
    }

    .hero {
      min-height: 560px;
    }

    .hero-content {
      padding: 3.2rem 1rem 2.5rem;
    }

    .content-grid {
      padding: 1.4rem 1rem;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .document-row {
      grid-template-columns: 1fr;
    }

    .site-footer {
      grid-template-columns: 1fr;
      grid-template-areas:
        "emblem"
        "summary"
        "nav"
        "legal";
      padding: 1.6rem 1rem;
    }

    .site-footer .legal {
      justify-self: start;
    }
  }
</style>