---

<Layout title="Crew" current="crew">
  <main class="interior-shell">
    <section class="page-hero">
      <p class="eyebrow">Crew Manifest</p>
      <h1>Crew</h1>
      <p class="dek">
        The officers, specialists, educators, diplomats, physicians, scientists, and mission leaders assigned to USS Kepler.
      </p>
    </section>

    <div class="content-layout">
      <article class="main-content">
        <section class="prose-block">
          <h2>Senior Staff</h2>
          <p>
            Kepler’s senior staff reflects the ship’s Frontier Initiative mandate:
            command, medicine, sciences, communications, diplomacy, education,
            operations, and institutional memory working as one mission team.
          </p>
        </section>

        {groups.map((group) => (
          <section class="staff-section" aria-labelledby={group.toLowerCase().replaceAll(" ", "-")}>
            <div class="section-heading">
              <p class="section-kicker">Senior Staff</p>
              <h2 id={group.toLowerCase().replaceAll(" ", "-")}>{group}</h2>
            </div>

            <div class="staff-grid">
              {seniorStaff
                .filter((officer) => officer.group === group)
                .map((officer) => (
                  <article class={`staff-card division-${officer.divisionColor.toLowerCase()}`}>
                    <div class="staff-card-bar" aria-hidden="true"></div>
                    <div class="staff-card-header">
                      <div class="identity-block">
                        <div class="rank-line">
                          <div class={`pips ${officer.pipBar ? "pips-with-bar" : ""}`} aria-label={`${officer.rank} rank pips`}>
                            <div class="pip-row">
                              {officer.pipTypes.map((pipType) => (
                                <svg class="pip" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                  <circle class="pip-outer" cx="12" cy="12" r="9" />
                                  {pipType === "hollow" && <circle class="pip-inner" cx="12" cy="12" r="5.2" />}
                                </svg>
                              ))}
                            </div>
                            {officer.pipBar && <span class="pip-bar" aria-hidden="true"></span>}
                          </div>
                          <span class="rank-separator" aria-hidden="true">|</span>
                          <p class="rank">{officer.rank}</p>
                        </div>
                        <div class="name-line">
                          <h3>{officer.name}</h3>
                          <p class="position">{officer.position}</p>
                        </div>
                      </div>
                      <a class="view-log" href={officer.logPath} aria-label={`View logs for ${officer.name}`}>
                        View Log <span aria-hidden="true">→</span>
                      </a>
                    </div>
                    <dl class="staff-meta">
                      <div>
                        <dt>Division</dt>
                        <dd>{officer.division}</dd>
                      </div>
                      <div>
                        <dt>Service Yrs</dt>
                        <dd>{officer.serviceYears}</dd>
                      </div>
                      <div>
                        <dt>Age</dt>
                        <dd>{officer.age}</dd>
                      </div>
                      <div>
                        <dt>Species</dt>
                        <dd>{officer.species}</dd>
                      </div>
                      <div class="homeworld-meta">
                        <dt>Homeworld</dt>
                        <dd>{officer.city}, {officer.homeworld}</dd>
                      </div>
                    </dl>
                  </article>
                ))}
            </div>
          </section>
        ))}
      </article>

      <aside class="context-rail">
        <section class="rail-card metadata-card">
          <h2>Personnel Summary</h2>
          <dl>
            {railItems.map(([term, detail]) => (
              <div>
                <dt>{term}</dt>
                <dd>{detail}</dd>
              </div>
            ))}
          </dl>
        </section>

        <section class="rail-card related-card">
          <h2>Related Records</h2>
          <ul>
            <li><a href="/mission">Mission</a></li>
            <li><a href="/ship">USS Kepler</a></li>
            <li><a href="/logs/commanding-officer">Senior Staff Logs</a></li>
            <li><a href="/timeline">Timeline</a></li>
          </ul>
        </section>
      </aside>
    </div>
  </main>
</Layout>

<style>
  .staff-section {
    margin-top: clamp(2rem, 4vw, 3.5rem);
  }

  .section-heading {
    margin-bottom: 1rem;
  }

  .section-kicker {
    margin: 0 0 0.35rem;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted-text, #6f6a63);
  }

  .section-heading h2 {
    margin: 0;
  }

  .staff-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .staff-card {
    position: relative;
    overflow: hidden;
    padding: clamp(1.2rem, 2.5vw, 1.65rem) clamp(1.25rem, 3vw, 1.9rem);
    border: 1px solid rgba(0, 0, 0, 0.12);
    background: rgba(255, 255, 255, 0.7);
    border-radius: 0.85rem;
    box-sizing: border-box;
    width: 100%;
  }

  .staff-card-bar {
    position: absolute;
    inset: 0 auto 0 0;
    width: 0.3rem;
    background: #777;
  }

  .division-red .staff-card-bar {
    background: #a71313;
  }

  .division-gold .staff-card-bar {
    background: #d6a444;
  }

  .division-blue .staff-card-bar {
    background: #2b53a7;
  }

  .staff-card-header {
    min-width: 0;
    padding-right: 6.25rem;
  }

  .identity-block {
    max-width: 100%;
  }

  .staff-card .view-log {
    position: absolute;
    top: clamp(1.2rem, 2.5vw, 1.65rem);
    right: clamp(1.25rem, 3vw, 1.9rem);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.64rem;
    font-weight: 850;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--muted-text, #6f6a63);
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .staff-card .view-log:hover {
    color: var(--body-text, #292521);
  }

  .rank-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.38rem;
    align-items: center;
    margin-bottom: 0.7rem;
  }

  .rank-separator {
    color: rgba(0, 0, 0, 0.26);
    font-weight: 700;
    margin: 0 0.18rem;
  }

  .rank {
    margin: 0;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
    color: var(--muted-text, #6f6a63);
  }

  .pips {
    display: inline-grid;
    gap: 0.16rem;
    align-items: center;
    margin: 0;
  }

  .pip-row {
    display: inline-flex;
    gap: 0.22rem;
    align-items: center;
  }

  .pip-bar {
    display: block;
    width: 100%;
    height: 0.16rem;
    border-radius: 999px;
    background: #292521;
  }

  .pip {
    display: block;
    width: 0.68rem;
    height: 0.68rem;
    flex: 0 0 auto;
  }

  .pip-outer {
    fill: #292521;
  }

  .pip-inner {
    fill: rgba(255, 255, 255, 0.86);
  }

  .name-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.72rem;
    align-items: baseline;
    margin-bottom: 0.78rem;
  }

  .staff-card h3 {
    margin: 0;
    font-size: clamp(1.18rem, 1.55vw, 1.42rem);
    font-weight: 820;
    line-height: 1.05;
    letter-spacing: -0.025em;
  }

  .position {
    margin: 0;
    color: var(--body-text, #292521);
    font-size: clamp(0.78rem, 0.95vw, 0.9rem);
    font-weight: 760;
  }

  .staff-meta {
    display: grid;
    grid-template-columns: 7rem 6rem 4rem minmax(6rem, 7.5rem) minmax(17rem, 1fr);
    gap: 0.65rem 1.35rem;
    align-items: start;
    margin: 0;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .staff-meta div {
    display: grid;
    gap: 0.25rem;
    align-items: start;
  }

  .staff-meta dt {
    font-size: 0.54rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
    color: var(--muted-text, #6f6a63);
  }

  .staff-meta dd {
    margin: 0;
    line-height: 1.22;
    font-size: clamp(0.8rem, 0.95vw, 0.9rem);
    color: rgba(0, 0, 0, 0.82);
  }

  .homeworld-meta {
    min-width: 0;
  }

  .homeworld-meta dd {
    overflow-wrap: normal;
    white-space: nowrap;
    text-overflow: clip;
  }

  @media (max-width: 900px) {
    .staff-meta {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .homeworld-meta {
      grid-column: 1 / -1;
    }

    .homeworld-meta dd {
      white-space: normal;
    }
  }

  @media (max-width: 560px) {
    .staff-card-header {
      padding-right: 0;
    }

    .staff-card .view-log {
      position: static;
      margin: 0 0 0.85rem;
      font-size: 0.68rem;
    }

    .staff-meta {
      grid-template-columns: 1fr;
    }

    .homeworld-meta {
      grid-column: auto;
    }
  }
</style>