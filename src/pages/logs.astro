---
import Layout from "../layouts/layout.astro";

const logCards = [
  {
    label: "CAPTAIN’S\nLOG",
    title: "Command Perspective",
    body: "Formal and reflective entries from Kepler’s commanding officer, including mission framing and strategic observations.",
    href: "/logs/captains-log",
  },
  {
    label: "OFFICER\nLOGS",
    title: "Department Records",
    body: "Entries from the executive officer, chief medical officer, chief science officer, engineering, and operations.",
    href: "/logs/officer-logs",
  },
  {
    label: "MISSION\nCHRONICLE",
    title: "Operational Sequence",
    body: "Chronological records of departures, assignments, field observations, and post-mission reflections.",
    href: "/logs/mission-chronicle",
  },
];

const railItems = [
  ["Section", "Logs"],
  ["Primary Record", "Captain’s Log"],
  ["Vessel", "USS Kepler NCC-83639"],
  ["Opening Entry", "Leaving Spacedock"],
  ["Launch Stardate", "80782.420"],
];
---

<Layout title="Logs" current="logs">
  <main class="interior-shell">
    <section class="page-hero">
      <p class="eyebrow">Section Overview</p>
      <h1>Logs</h1>
      <p class="dek">
        Personal and operational records from USS Kepler’s Frontier Initiative assignment.
      </p>
    </section>

    <div class="content-layout">
      <article class="main-content">
        <section class="prose-block">
          <h2>Overview</h2>
          <p>
            Logs are the narrative layer of the Kepler archive. They record how
            the mission is understood by the people carrying it out: command
            officers, department heads, specialists, and field teams working at
            the boundary between Federation policy and lived experience.
          </p>
        </section>

        <section class="logs-grid">
          {logCards.map((card) => (
            <a class="logs-card" href={card.href}>
              <p class="card-label">{card.label}</p>
              <h2>{card.title}</h2>
              <p>{card.body}</p>
              <span class="card-action">Open Record</span>
            </a>
          ))}
        </section>

        <section class="prose-block section-note">
          <h2>First Entry</h2>
          <p>
            Captain’s Log. Stardate 80782.420. USS Kepler is preparing to leave
            spacedock and begin its first assignment under the Frontier Initiative.
          </p>
        </section>
      </article>

      <aside class="context-rail">
        <section class="rail-card">
          <p class="rail-kicker">Log Record</p>
          <h2>USS Kepler</h2>
          <p>
            The Logs section gathers personal and operational records from the
            crew, preserving the reflective side of Kepler’s work.
          </p>
        </section>

        <section class="rail-card metadata-card">
          <h2>Archive Details</h2>
          <dl>
            {railItems.map(([term, detail]) => (
              <div>
                <dt>{term}</dt>
                <dd>{detail}</dd>
              </div>
            ))}
          </dl>
        </section>

        <section class="rail-card related-card">
          <h2>Related Records</h2>
          <ul>
            <li><a href="/mission">Mission Framework</a></li>
            <li><a href="/ship">Ship Profile</a></li>
            <li><a href="/crew">Crew Directory</a></li>
          </ul>
        </section>
      </aside>
    </div>
  </main>
</Layout>