---
import Layout from "../layouts/layout.astro";

const eras = [
  {
    label: "Frontier Initiative Era",
    description:
      "The formal transition from planning to operational deployment.",
    events: [
      {
        date: "28 Jul 2403",
        title: "Initial Operational Deployment",
        description:
          "USS Kepler departs the Deneb Sector for initial Frontier Initiative deployment. Mission priorities include settlement resilience assessment, regional infrastructure support, and long-duration civic partnership operations.",
      },
      {
        date: "18 Jul 2403",
        title: "Shakedown Operations Begin",
        description:
          "USS Kepler begins post-launch evaluation, systems certification, and crew integration exercises prior to Frontier Initiative deployment.",
        gap: "gap-short",
      },
      {
        date: "04 Jul 2403",
        title: "USS Kepler Launched",
        description:
          "USS Kepler, NCC-83639, is launched from Deneb IV Fleet Yards as the third Starfleet vessel to carry the name Kepler.",
        gap: "gap-tight",
      },
      {
        date: "03 Jul 2403",
        title: "Doctrine of Support Filed",
        description:
          "Admiral Jean-Luc Picard files the operating doctrine later associated with USS Kepler and its Frontier Initiative deployment model.",
        href: "/archive/doctrine",
        linkLabel: "Doctrine of Support",
        gap: "gap-tight",
      },
      {
        date: "23 Jun 2403",
        title: "Frontier Initiative Directive Issued",
        description:
          "Commodore Tuvok publishes the operational framework governing Frontier Initiative deployments, settlement support priorities, and distributed capability development.",
        href: "/archive/the-frontier-initiative",
        linkLabel: "The Frontier Initiative",
        gap: "gap-short",
      },
      {
        date: "10 Jun 2403",
        title: "State of the Federation Published",
        description:
          "The Historical Analysis Division releases a post-Frontier Day assessment of Federation cohesion, decentralization, institutional trust, and long-term renewal.",
        href: "/archive/state-of-the-federation-2403",
        linkLabel: "State of the Federation, 2403",
        gap: "gap-short",
      },
    ],
  },
  {
    label: "Framework Development",
    description:
      "Planning documents, operational frameworks, and personnel decisions that prepared Kepler for active service.",
    events: [
      {
        date: "18 May 2403",
        title: "Primary Systems Integration Complete",
        description:
          "USS Kepler enters final integration and certification testing at Deneb IV Fleet Yards. Mission systems, fabrication facilities, and long-duration support infrastructure are validated for Frontier Initiative operations.",
      },
      {
        date: "14 Feb 2403",
        title: "Keel Laid: USS Kepler",
        description:
          "Construction begins on USS Kepler, NCC-83639, at Deneb IV Fleet Yards. The vessel is configured for extended Frontier Initiative operations.",
        gap: "gap-long",
      },
      {
        date: "21 Oct 2402",
        title: "Senior Staff Selection Board Concludes",
        description:
          "Starfleet Command approves key command and departmental assignments for USS Kepler. Final personnel assignments continue through the following operational cycle.",
        gap: "gap-medium",
      },
      {
        date: "19 Jul 2402",
        title: "Settlement Continuum Adopted",
        description:
          "The Federation Settlement Development Office publishes a standardized framework for evaluating community capability, resilience, and regional integration.",
        href: "/archive/settlement-continuum",
        linkLabel: "The Settlement Continuum",
        gap: "gap-medium",
      },
    ],
  },
  {
    label: "Post-Frontier Day Reconstruction",
    description:
      "The period immediately following the Frontier Day Crisis, when Starfleet began reassessing centralization, resilience, and fleet operations.",
    events: [
      {
        date: "13 Oct 2401",
        title: "Commanding Officer Assigned",
        description:
          "The future commanding officer of USS Kepler receives assignment orders and prepares to oversee final fitting and shakedown preparations.",
        href: "/logs/commanding-officer/78782-306",
        linkLabel: "Captain's Log 78782.306",
      },
      {
        date: "22 Jun 2401",
        title: "Frontier Initiative Working Group Established",
        description:
          "Starfleet Command convenes a multidisciplinary planning group under the direction of Commodore Tuvok.",
        gap: "gap-long",
      },
      {
        date: "18 Apr 2401",
        title: "Strategic Assessment Ordered",
        description:
          "Admiral Kathryn Janeway secures authorization for a comprehensive review of Federation resilience, regional support capacity, and settlement development programs.",
        gap: "gap-medium",
      },
      {
        date: "12 Apr 2401",
        title: "Stargazer Anomaly",
        description:
          "The events surrounding the USS Stargazer and the Jurati-Borg alliance begin reshaping Federation thinking about cooperation, trust, and emerging threats.",
        gap: "gap-tight",
      },
      {
        date: "05 Apr 2401",
        title: "Frontier Day Crisis",
        description:
          "A coordinated Borg infiltration compromises Starfleet systems and results in severe losses across multiple vessels and installations.",
        gap: "gap-tight",
      },
    ],
  },
  {
    label: "Historical Record",
    description:
      "Foundational events and institutional crises that shaped the Federation before the Frontier Initiative era.",
    events: [
      {
        date: "2399",
        title: "Synthetic Ban Lifted",
        description:
          "Federation policy regarding synthetic life is formally reversed, beginning a broader reassessment of post-Mars security doctrine and institutional trust.",
      },
      {
        date: "2387",
        title: "Romulan Supernova",
        description:
          "The destruction of the Romulan homeworld destabilizes the Beta Quadrant and exposes significant limits in Federation evacuation capacity and interstellar crisis response.",
        gap: "gap-long",
      },
      {
        date: "2385",
        title: "Mars Attack",
        description:
          "The attack on Utopia Planitia Fleet Yards destroys the Federation rescue effort and contributes to the later synthetic ban.",
        gap: "gap-medium",
      },
      {
        date: "2373-2375",
        title: "Dominion War",
        description:
          "The largest conflict in Federation history demonstrates both the strengths and vulnerabilities of interstellar institutions during prolonged crisis.",
        gap: "gap-long",
      },
      {
        date: "2373",
        title: "Second Borg Incursion",
        description:
          "A second Borg attack on Earth reinforces the long-term strategic and psychological impact of collective threats on Federation institutions.",
        gap: "gap-tight",
      },
      {
        date: "2367",
        title: "Wolf 359",
        description:
          "The Borg incursion led by Locutus devastates Starfleet and becomes a defining institutional trauma for an entire generation of officers.",
        gap: "gap-long",
      },
      {
        date: "2344",
        title: "Narendra III Incident",
        description:
          "The sacrifice of USS Enterprise-C while defending a Klingon outpost strengthens Federation-Klingon relations during a fragile period.",
        gap: "gap-era",
      },
      {
        date: "2293",
        title: "Khitomer Accords Signed",
        description:
          "Federation and Klingon leaders formalize a lasting peace, reshaping Alpha Quadrant politics for generations.",
        gap: "gap-era",
      },
      {
        date: "2293",
        title: "Praxis Explodes",
        description:
          "The destruction of Praxis triggers political reform within the Klingon Empire and sets the stage for a new era of diplomacy.",
        gap: "gap-tight",
      },
      {
        date: "2286",
        title: "Spacedock Opens",
        description:
          "Earth Spacedock becomes one of the most recognizable symbols of Federation exploration, diplomacy, and fleet operations.",
        gap: "gap-medium",
      },
      {
        date: "2256",
        title: "Federation-Klingon War",
        description:
          "The Federation faces a major existential conflict with the Klingon Empire, reinforcing the importance of alliance-building and interstellar cooperation.",
        gap: "gap-era",
      },
      {
        date: "2161 Aug",
        title: "United Federation of Planets Founded",
        description:
          "Earth, Vulcan, Andoria, and Tellar establish the United Federation of Planets, creating shared civic institutions across member worlds.",
        gap: "gap-century",
      },
      {
        date: "2156",
        title: "Earth-Romulan War",
        description:
          "The conflict establishes many of the strategic realities that later influence Federation defense, diplomacy, and frontier policy.",
        gap: "gap-medium",
      },
      {
        date: "2063 Apr",
        title: "First Contact",
        description:
          "Zefram Cochrane's warp flight results in open contact between Humans and Vulcans. The event becomes a foundational moment in Federation history and is later commemorated as First Contact Day.",
        gap: "gap-century",
      },
    ],
  },
];
---

<Layout
  title="Timeline"
  description="Follow USS Kepler from Frontier Initiative planning through construction, launch, shakedown, and active service."
>
  <main class="interior-shell">
    <section class="page-hero" aria-labelledby="timeline-title">
      <p class="eyebrow">Memory Alpha</p>
      <h1 id="timeline-title">Timeline</h1>
      <p class="dek">
        A chronological record of the events, crises, reforms, and operational milestones that ultimately led to the creation and deployment of USS Kepler and the Frontier Initiative.
      </p>
    </section>

    <section class="timeline-map" aria-label="USS Kepler timeline">
      {eras.map((era) => (
        <section class="timeline-era" aria-labelledby={`era-${era.label.toLowerCase().replaceAll(" ", "-")}`}>
          <div class="era-marker">
            <h2 id={`era-${era.label.toLowerCase().replaceAll(" ", "-")}`}>{era.label}</h2>
            <p>{era.description}</p>
          </div>

          <div class="era-events">
            {era.events.map((event) => (
              <article class={`timeline-event ${event.gap ?? "gap-standard"}`}>
                <time>{event.date}</time>
                <div class="event-card">
                  <h3>{event.title}</h3>
                  <p>{event.description}</p>
                  {event.href && (
                    <a href={event.href} class="event-link">
                      {event.linkLabel ?? "Related Record"}
                      <span aria-hidden="true">›</span>
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </section>
  </main>
</Layout>

<style>

  .page-hero {
    max-width: 1120px;
  }

  .page-hero .dek {
    max-width: 920px;
  }

  .timeline-map {
    display: grid;
    max-width: 1120px;
    gap: clamp(2.25rem, 5vw, 3.75rem);
  }

  .timeline-era {
    display: grid;
    grid-template-columns: minmax(190px, 260px) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  .era-marker {
    position: sticky;
    top: 1.5rem;
    padding: 0.25rem 0 1.25rem;
    border-top: 3px solid var(--operations);
  }

  .era-marker h2 {
    margin: 0.85rem 0 0;
    color: var(--ink);
    font-family: "Orbitron", sans-serif;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .era-marker p {
    margin: 0.85rem 0 0;
    color: var(--muted);
    font-family: "Crimson Text", serif;
    font-size: 1.05rem;
    line-height: 1.45;
  }

  .era-events {
    position: relative;
    display: grid;
    gap: 0;
    padding-left: 1.5rem;
  }

  .era-events::before {
    position: absolute;
    top: 0.4rem;
    bottom: 0.4rem;
    left: 0.35rem;
    width: 1px;
    content: "";
    background: linear-gradient(180deg, rgba(167, 19, 19, 0.45), rgba(43, 83, 167, 0.18));
  }

  .timeline-event {
    position: relative;
    display: grid;
    grid-template-columns: minmax(108px, 132px) minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 1.75rem);
    align-items: start;
  }

  .timeline-event + .timeline-event {
    margin-top: 1.15rem;
  }

  .timeline-event.gap-tight {
    margin-top: 0.9rem;
  }

  .timeline-event.gap-short {
    margin-top: 1.35rem;
  }

  .timeline-event.gap-medium {
    margin-top: 2rem;
  }

  .timeline-event.gap-long {
    margin-top: 2.85rem;
  }

  .timeline-event.gap-era {
    margin-top: 4.25rem;
  }

  .timeline-event.gap-century {
    margin-top: 5.5rem;
  }

  .timeline-event::before {
    position: absolute;
    top: 0.55rem;
    left: -1.15rem;
    width: 0.66rem;
    height: 0.66rem;
    box-sizing: border-box;
    content: "";
    background: var(--paper);
    border: 2px solid var(--command);
    border-radius: 999px;
    box-shadow: 0 0 0 4px rgba(167, 19, 19, 0.08);
    transform: translateX(-50%);
  }

  .timeline-event time {
    padding-top: 0.18rem;
    color: var(--command);
    font-family: "Orbitron", sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    line-height: 1.35;
    white-space: nowrap;
    text-transform: uppercase;
  }

  .event-card {
    position: relative;
    padding: 1.1rem 1.2rem 1.15rem;
    background: rgba(255, 255, 255, 0.28);
    border: 1px solid rgba(17, 17, 17, 0.14);
    box-shadow: inset 3px 0 0 rgba(214, 164, 68, 0.72);
  }

  .event-card h3 {
    margin: 0;
    color: var(--ink);
    font-family: "Inter", sans-serif;
    font-size: 0.92rem;
    font-weight: 850;
    letter-spacing: 0.055em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .event-card p {
    margin: 0.65rem 0 0;
    color: #28241f;
    font-family: "Crimson Text", serif;
    font-size: 1.08rem;
    line-height: 1.55;
  }

  .event-link {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
    margin-top: 0.85rem;
    color: var(--command);
    font-family: "Orbitron", sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .event-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  @media (max-width: 860px) {
    .timeline-era {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .era-marker {
      position: static;
      padding-bottom: 0.85rem;
      border-top: 3px solid var(--operations);
      border-bottom: 1px solid rgba(17, 17, 17, 0.12);
    }
  }

  @media (max-width: 620px) {
    .era-events {
      padding-left: 1.1rem;
    }

    .timeline-event {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }

    .timeline-event::before {
      left: -0.75rem;
    }
  }
</style>
