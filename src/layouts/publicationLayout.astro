---
import Layout from "./layout.astro";

interface Props {
  title: string;
  pubTitle?: string;
  subtitle?: string;
  recordType?: string;
  stardate?: string;
  archiveDate?: string;
  federationDate?: string;
  author?: string;
  department?: string;
  heroImage?: string;
  heroAlt?: string;
}

const frontmatter = Astro.props.frontmatter ?? Astro.props;

const {
  title,
  pubTitle,
  subtitle,
  recordType = "Archive Record",
  stardate,
  archiveDate,
  federationDate,
  author,
  department,
  heroImage,
  heroAlt,
} = frontmatter;

const displayTitle = pubTitle ?? title;
const displayHeroAlt = heroAlt ?? displayTitle;
const displayDate = federationDate ?? archiveDate;

---

<Layout title={title}>
  <main class="interior-shell publication-shell">
    <div class="publication-layout">
      <article class="publication-content">
        <section class="publication-header">
          <p class="publication-type">{recordType}</p>

          <h1>{displayTitle}</h1>

          {subtitle && (
            <p class="publication-subtitle">{subtitle}</p>
          )}

          {heroImage && (
            <figure class="publication-hero-image">
              <img src={heroImage} alt={displayHeroAlt} />
            </figure>
          )}
        </section>
        <slot />

        {(author || department || stardate || displayDate) && (
          <section class="report-closing">
            <dl class="report-meta closing">
              {author && (
                <div class="meta-row">
                  <dt>Author</dt>
                  <dd>{author}</dd>
                </div>
              )}

              {department && (
                <div class="meta-row">
                  <dt>Department</dt>
                  <dd>{department}</dd>
                </div>
              )}

              {stardate && (
                <div class="meta-row">
                  <dt>Stardate</dt>
                  <dd>{stardate}</dd>
                </div>
              )}

              {displayDate && (
                <div class="meta-row">
                  <dt>Terran Date</dt>
                  <dd>{displayDate}</dd>
                </div>
              )}
            </dl>
          </section>
        )}
      </article>

      <aside class="publication-rail">
        <section class="rail-card publication-about-card">
          <p class="rail-kicker primary">About the Archive</p>

          <p class="rail-lede">
            USS Kepler is a living Star Trek fan archive exploring
            service, citizenship, belonging, and the institutions that connect worlds.
          </p>

          <p>
            These records are presented as a fictional historical archive:
            doctrine papers, mission reports, captain's logs, personnel files,
            and cultural records set in the years following
            <strong>Star Trek: Picard Season 3</strong>.
          </p>

          <p>
            The project is a speculative companion to
            <a href="https://www.amidthenoise.com">Amid the Noise</a>, using the
            Star Trek universe to ask what civic life might become when the
            frontier is not conquest, but connection.
          </p>

          <nav class="rail-links" aria-label="Publication reference links">
            <a href="mailto:info@usskepler.org">Contact</a>
            <span aria-hidden="true">|</span>
            <a href="/about-the-project">About the Project</a>
          </nav>
        </section>
      </aside>
    </div>
  </main>
</Layout>

<style>
  .publication-shell {
    max-width: 1240px;
    margin: 0 auto;
    padding-inline: clamp(1rem, 2.5vw, 2.5rem);
  }

  .publication-header {
    max-width: 780px;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(17, 17, 17, 0.12);
  }

  .report-meta {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    background: transparent;
  }

  .meta-row {
    display: grid;
    grid-template-columns: 7.5rem minmax(0, 1fr);
    gap: 1rem;
    align-items: baseline;
  }


  .report-meta dt {
    color: var(--command);
    font-family: "Orbitron", sans-serif;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .report-meta dd {
    margin: 0;
    font-family: "Crimson Text", serif;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.2;
    text-align: left;
  }

  .publication-type {
    margin: 0 0 0.75rem;
    color: var(--operations);
    font-family: "Inter", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
    opacity: 1;
  }

  .publication-shell h1 {
    max-width: 760px;
    font-size: clamp(1.45rem, 2.55vw, 2.65rem);
    line-height: 1.12;
    letter-spacing: 0.055em;
  }

  .publication-subtitle {
    max-width: 760px;
    margin: 1rem 0 0;
    font-family: "Crimson Text", serif;
    font-size: 1.25rem;
    line-height: 1.45;
  }

  .publication-hero-image {
    margin: 2rem 0 0;
  }

  .publication-hero-image img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
  }

  .publication-layout {
    display: grid;
    grid-template-columns: minmax(0, 760px) minmax(300px, 360px);
    gap: clamp(2.75rem, 5vw, 5.5rem);
    align-items: start;
  }

  .publication-content {
    min-width: 0;
  }

  .publication-content :global(h2) {
    margin-top: 2.5rem;
    padding-bottom: 1.25rem;
    font-family: "Inter", sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .publication-content :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.35rem;
    padding-top: 0.5rem;
    padding-bottom: 0;
    font-family: "Inter", sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .publication-content :global(hr) {
    border: 0;
    height: 1px;
    margin: 2.5rem 0;
    background: rgba(17, 17, 17, 0.1);
  }

  .publication-content > :global(p),
  .publication-content > :global(ul),
  .publication-content > :global(ol) {
    font-family: "Crimson Text", serif;
    font-size: 1.25rem;
    line-height: 1.7;
  }

  .publication-content :global(li) {
    font-family: "Crimson Text", serif;
    font-size: 1.25rem;
    line-height: 1.7;
  }

  .report-closing {
    max-width: 680px;
    margin-top: 3.25rem;
    padding: 1rem 1.15rem;
    border: 1px solid rgba(17, 17, 17, 0.1);
    background: rgba(255, 255, 255, 0.42);
  }

  .report-closing .report-meta {
    max-width: none;
  }

  .record-navigation {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(17, 17, 17, 0.08);
  }

  .publication-rail {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .publication-about-card {
    position: sticky;
    top: 1.5rem;
    padding: 1.75rem;
    background: rgba(255, 255, 255, 0.22);
  }

  .publication-about-card .rail-kicker {
    margin-bottom: 1rem;
    color: inherit;
    font-family: "Inter", sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .publication-about-card p {
    font-family: "Crimson Text", serif;
    font-size: 1.02rem;
    line-height: 1.58;
  }

  .publication-about-card strong {
    font-weight: 600;
  }

  .publication-about-card p a {
    color: var(--command);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
    text-decoration-color: rgba(167, 19, 19, 0.35);
    transition: color 160ms ease, text-decoration-color 160ms ease;
  }

  .publication-about-card p a:hover {
    color: #7f0f0f;
    text-decoration-color: var(--command);
  }

  .publication-about-card p + p {
    margin-top: 0.85rem;
  }

  .publication-about-card .rail-lede {
    margin-top: 0;
    font-size: 1.05rem;
    line-height: 1.55;
  }

  .rail-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
    margin-top: 1.6rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(17, 17, 17, 0.08);
    color: var(--muted);
    font-family: "Orbitron", sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .rail-links a {
    color: var(--command);
  }

  .rail-links a {
    transition: color 160ms ease;
  }

  .rail-links a:hover {
    color: #7f0f0f;
  }

  @media (max-width: 1180px) {
    .publication-layout {
      grid-template-columns: 1fr;
    }
    .publication-about-card {
      position: static;
    }
  }
</style>