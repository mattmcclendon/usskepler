---
import Layout from "./layout.astro";

interface Props {
  title: string;
  pubTitle?: string;
  subtitle?: string;
  excerpt?: string;
  description?: string;
  recordType?: string;
  stardate?: string;
  archiveDate?: string;
  federationDate?: string;
  author?: string;
  department?: string;
  heroImage?: string;
  heroAlt?: string;
  relatedRecords?: Array<{
    title: string;
    href: string;
  }>;
}

const frontmatter = Astro.props.frontmatter ?? Astro.props;

const {
  title,
  pubTitle,
  subtitle,
  excerpt,
  description,
  recordType = "Archive Record",
  stardate,
  archiveDate,
  federationDate,
  author,
  department,
  heroImage,
  heroAlt,
} = frontmatter;

const relatedRecords = (frontmatter.relatedRecords ?? Astro.props.relatedRecords ?? []).slice(0, 3);

const displayTitle = pubTitle ?? title;
const displayHeroAlt = heroAlt ?? displayTitle;
const displayDate = federationDate ?? archiveDate;
const metaDescription =
  description ??
  excerpt ??
  subtitle ??
  `${displayTitle}${stardate ? `, Stardate ${stardate}` : ""}, a record from the USS Kepler archive.`;
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const logsIndex = pathSegments.indexOf("logs");
const logRoleSlug = logsIndex >= 0 ? pathSegments[logsIndex + 1] : undefined;
const isLogRecord = Boolean(logRoleSlug && stardate);
const roleHref = isLogRecord ? `/logs/${logRoleSlug}/` : undefined;
const roleLabel = author ? String(author).replace(/\s*\([^)]*\)\s*$/, "") : "Crewmember";

---

<Layout title={title} description={metaDescription}>
  <main class="interior-shell publication-shell">
    <div class="publication-layout">
      <article class="publication-content">
        <section class="publication-header">
          <p class="publication-type">{recordType}</p>

          <h1>{displayTitle}</h1>

          {subtitle && (
            <p class="publication-subtitle">{subtitle}</p>
          )}

          {heroImage && (
            <figure class="publication-hero-image">
              <img src={heroImage} alt={displayHeroAlt} loading="lazy" decoding="async" />
            </figure>
          )}
        </section>
        <slot />

        {(author || department || stardate || displayDate) && (
          <section class="report-closing">
            <dl class="report-meta closing">
              {author && (
                <div class="meta-row">
                  <dt>Author</dt>
                  <dd>{author}</dd>
                </div>
              )}

              {department && (
                <div class="meta-row">
                  <dt>Department</dt>
                  <dd>{department}</dd>
                </div>
              )}

              {stardate && (
                <div class="meta-row">
                  <dt>Stardate</dt>
                  <dd>{stardate}</dd>
                </div>
              )}

              {displayDate && (
                <div class="meta-row">
                  <dt>Terran Date</dt>
                  <dd>{displayDate}</dd>
                </div>
              )}
            </dl>
            {isLogRecord && (
              <nav class="publication-breadcrumb publication-breadcrumb--footer" aria-label="Breadcrumb">
                <a href="/logs/">Logs</a>
                <span aria-hidden="true">/</span>
                {roleHref ? <a href={roleHref}>{roleLabel}</a> : <span>{roleLabel}</span>}
                <span aria-hidden="true">/</span>
                <span>{stardate}</span>
              </nav>
            )}
          </section>
        )}
      </article>

      <aside class="publication-rail">
        <section class="rail-card publication-about-card">
          <p class="rail-kicker primary">About the Archive</p>

          <p class="rail-lede">
            USS Kepler is a living Star Trek fan archive exploring
            service, citizenship, belonging, and the institutions that connect worlds.
          </p>

          <p>
            These records are presented as a fictional historical archive:
            doctrine papers, mission reports, captain's logs, personnel files,
            and cultural records set in the years following
            <strong>Star Trek: Picard Season 3</strong>.
          </p>

          <p>
            The project is a speculative companion to
            <a href="https://www.amidthenoise.com">Amid the Noise</a>, using the
            Star Trek universe to ask what civic life might become when the
            frontier is not conquest, but connection.
          </p>

          <nav class="rail-links" aria-label="Publication reference links">
            <a href="mailto:info@usskepler.org">Contact</a>
            <span aria-hidden="true">|</span>
            <a href="/about-the-project">About the Project</a>
          </nav>
        </section>

        {Array.isArray(relatedRecords) && relatedRecords.length > 0 && (
          <section class="rail-card publication-related-card">
            <p class="rail-kicker primary">Related Records</p>
            <ul>
              {relatedRecords.map((record) => (
                <li>
                  <a href={record.href}>{record.title}</a>
                </li>
              ))}
            </ul>
          </section>
        )}
      </aside>
    </div>
  </main>
</Layout>

<style>
  .publication-shell {
    max-width: 1240px;
    margin: 0 auto;
    padding-inline: clamp(1rem, 2.5vw, 2.5rem);
  }

  .publication-layout {
    display: grid;
    grid-template-columns: minmax(0, 760px) minmax(300px, 360px);
    gap: clamp(2.75rem, 5vw, 5.5rem);
    align-items: start;
  }

  .publication-content {
    min-width: 0;
    overflow: hidden;
    color: var(--ink);
  }

  .publication-header {
    max-width: 780px;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(17, 17, 17, 0.12);
  }

  .publication-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    margin: 0;
    color: var(--muted);
    font-family: "Orbitron", sans-serif;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .publication-breadcrumb--footer {
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px solid rgba(17, 17, 17, 0.08);
  }

  .publication-breadcrumb a {
    color: var(--command);
    text-decoration: none;
  }

  .publication-breadcrumb a:hover {
    color: #7f0f0f;
  }

  .publication-breadcrumb span {
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
  }

  .publication-header .publication-type,
  .publication-header .publication-type.primary {
    margin: 0 0 0.75rem;
    color: var(--command) !important;
    font-family: "Orbitron", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .publication-shell h1 {
    max-width: 760px;
    font-size: clamp(1.45rem, 2.55vw, 2.65rem);
    line-height: 1.12;
    letter-spacing: 0.055em;
  }

  .publication-subtitle {
    max-width: 760px;
    margin: 1rem 0 0;
    font-family: "Crimson Text", serif;
    font-size: 1.25rem;
    line-height: 1.45;
  }

  .publication-hero-image {
    margin: 2rem 0 0;
  }

  .publication-hero-image img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
  }

  /* Markdown typography */
  .publication-content :global(h2) {
    max-width: 720px;
    margin: 2.5rem 0 1rem;
    padding: 0;
    color: var(--ink);
    font-family: "Orbitron", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .publication-content :global(h3) {
    max-width: 720px;
    margin: 1.65rem 0 0.7rem;
    padding: 0;
    color: var(--ink);
    font-family: "Orbitron", sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .publication-content > :global(p),
  .publication-content :global(li),
  .publication-content :global(blockquote p) {
    max-width: 720px;
    color: var(--ink);
    font-family: "Crimson Text", serif;
    font-size: 1.25rem;
    line-height: 1.7;
  }

  .publication-content > :global(p) {
    margin: 0 0 1.25rem;
  }

  .publication-content :global(em),
  .publication-content :global(strong) {
    font-size: inherit;
    line-height: inherit;
  }

  .publication-content :global(ul),
  .publication-content :global(ol) {
    max-width: 720px;
    margin: 0 0 1.6rem;
    padding-left: 1.35rem;
    font-family: "Crimson Text", serif;
  }

  .publication-content :global(li) {
    margin: 0 0 0.25rem;
  }

  .publication-content :global(hr) {
    max-width: 720px;
    border: 0;
    height: 1px;
    margin: 2.5rem 0;
    background: rgba(17, 17, 17, 0.12);
  }

  /* Quotes */
  .publication-content :global(blockquote) {
    box-sizing: border-box;
    max-width: 720px;
    margin: 1.75rem 0 2rem;
    padding: 0.2rem 0 0.2rem 1.25rem;
    border-left: 4px solid var(--operations);
    background: transparent;
  }

  .publication-content :global(blockquote p) {
    margin: 0 0 1rem;
    font-style: italic;
  }

  .publication-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* Tables */
  .publication-content :global(table) {
    width: 100%;
    max-width: 720px;
    margin: 1rem 0 2rem;
    border-collapse: collapse;
    font-family: "Crimson Text", serif;
    font-size: 1.15rem;
    line-height: 1.45;
  }

  .publication-content :global(th),
  .publication-content :global(td) {
    padding: 0.25rem 1.25rem 0.25rem 0;
    text-align: left;
    vertical-align: top;
  }

  .publication-content :global(th) {
    font-weight: 700;
  }

  /* Standard images */
  .publication-content :global(p:has(img:not(.log-marginalia))) {
    margin: 2rem 0 0.65rem;
    max-width: 100%;
  }

  .publication-content :global(p > img:not(.log-marginalia)),
  .publication-content :global(img:not(.log-marginalia)) {
    box-sizing: border-box;
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    padding: 0.35rem;
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid rgba(17, 17, 17, 0.09);
    border-radius: 2px;
    object-fit: contain;
  }

  /* Captions only: italic paragraph immediately after a standard image */
  .publication-content :global(p:has(img:not(.log-marginalia)) + p > em:only-child) {
    display: block;
    max-width: 720px;
    margin: 0.25rem 0 1.75rem;
    padding-left: 0.15rem;
    color: var(--muted);
    font-size: 0.98rem;
    font-style: italic;
    font-weight: 600;
    line-height: 1.45;
  }

  /* Marginalia images */
  .publication-content :global(p:has(img.log-marginalia)) {
    margin: 0;
    max-width: 100%;
  }

  .publication-content :global(img.log-marginalia),
  .publication-content :global(p > img.log-marginalia) {
    box-sizing: border-box;
    display: block;
    width: min(360px, 72vw);
    max-width: 100%;
    height: auto;
    margin: 2rem auto 1.75rem;
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
    object-fit: contain;
  }

  .publication-content :global(img.log-marginalia--wide),
  .publication-content :global(p > img.log-marginalia--wide) {
    width: min(700px, 100%);
  }

  .publication-content :global(img.log-marginalia--left),
  .publication-content :global(p > img.log-marginalia--left) {
    width: min(60%, 700px);
    margin: 2rem 0 1.75rem;
  }

  .publication-content > hr:last-of-type {
    display: none;
  }

  /* Closing metadata */
  .report-closing {
    max-width: 680px;
    margin-top: 1.5rem;
    padding: 1rem 1.15rem;
    border: 1px solid rgba(17, 17, 17, 0.1);
    background: rgba(255, 255, 255, 0.42);
  }

  .report-meta {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    background: transparent;
  }

  .report-closing .report-meta {
    max-width: none;
  }

  .meta-row {
    display: grid;
    grid-template-columns: 7.5rem minmax(0, 1fr);
    gap: 1rem;
    align-items: baseline;
  }

  .report-meta dt {
    color: var(--command);
    font-family: "Orbitron", sans-serif;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .report-meta dd {
    margin: 0;
    font-family: "Crimson Text", serif;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.2;
    text-align: left;
  }

  .record-navigation {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(17, 17, 17, 0.08);
  }

  /* Right rail */
  .publication-rail {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .publication-rail .rail-card {
    box-sizing: border-box;
    padding: 1.15rem 1.25rem;
    background: rgba(255, 255, 255, 0.24);
    border: 1px solid rgba(17, 17, 17, 0.11);
  }

  .publication-related-card a {
    color: inherit;
    text-decoration: none;
  }

  .publication-rail .rail-kicker,
  .publication-rail .rail-kicker.primary {
    margin: 0 0 0.95rem;
    color: var(--command) !important;
    font-family: "Orbitron", sans-serif;
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .publication-rail p,
  .publication-rail li {
    max-width: none;
    margin: 0 0 0.9rem;
    color: var(--ink);
    font-family: "Crimson Text", serif;
    font-size: 0.96rem;
    font-weight: 400;
    line-height: 1.5;
  }

  .publication-rail .rail-lede {
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.5;
  }

  .publication-related-card ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .publication-rail strong,
  .publication-rail a {
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
  }

  .publication-rail strong {
    font-weight: 600;
  }

  .publication-rail .rail-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    align-items: center;
    margin-top: 1.05rem;
    padding-top: 0.95rem;
    border-top: 1px solid rgba(17, 17, 17, 0.1);
    color: var(--muted);
    font-family: "Orbitron", sans-serif;
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .rail-links a {
    color: var(--command);
    transition: color 160ms ease;
  }

  .rail-links a:hover {
    color: #7f0f0f;
  }

  @media (max-width: 1180px) {
    .publication-layout {
      grid-template-columns: 1fr;
    }

    .publication-content {
      overflow: visible;
    }
  }

  @media (max-width: 720px) {
    .publication-content :global(img.log-marginalia) {
      width: min(280px, 78vw);
      margin: 1.5rem auto;
    }

    .publication-content :global(img.log-marginalia--left) {
      width: min(100%, 420px);
      margin: 1.5rem 0;
    }
  }
</style>
